rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return signedIn() && request.auth.uid in [
        "pBuzGhb1lTgaOx47SxC1i2RRfw22"
      ];
    }

    match /studentDrafts/{studentUid}/packs/{packId} {
      allow read: if signedIn() && (request.auth.uid == studentUid || isTeacher());
      allow write: if signedIn()
        && request.auth.uid == studentUid
        && request.resource.data.ownerUid == studentUid
        && request.resource.data.status == "draft";
    }


    match /{path=**}/packs/{packId} {
      allow read: if isTeacher();
    }
    match /levelPacks/{packId} {
      allow read: if true;
      allow write: if isTeacher() && request.resource.data.status == "published";
    }
  }
}



