{
  "name": "infection-blocks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "firebase:push-levels": "node --env-file=.env.local --import tsx scripts/pushLevelPacksToFirestore.ts",
    "android:init": "npm run build && cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.0.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/preferences": "^7.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "firebase": "^12.14.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
